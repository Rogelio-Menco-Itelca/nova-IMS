{
  "name": "ims-backend",
  "version": "1.0.0",
  "description": "Incident Management System - Backend (Express + MySQL + Socket.IO)",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "node sql/init-db.js",
    "db:reset": "node sql/init-db.js --reset",
