# ----- Servidor -----
PORT=3000
NODE_ENV=development

# ----- URLs públicas (WhatsApp / SMS / location share) -----
# Use una URL https accesible desde el celular. Sin esto, el enlace sale como localhost.
# Opción A — recomendada (producción o ngrok):
# PUBLIC_URL=https://tu-tunel.ngrok-free.app
# Opción B — solo desarrollo con ngrok (si PUBLIC_URL sigue en localhost):
# NGROK_URL=https://tu-tunel.ngrok-free.app
#
# ¿Cómo obtener la URL de ngrok?
# 1. Instala ngrok: https://ngrok.com/download
# 2. Crea cuenta y activa: ngrok config add-authtoken TU_TOKEN
# 3. En una terminal aparte ejecuta: ngrok http 3000
# 4. Copia la URL https que aparece (ej: https://abc123.ngrok-free.app)
# 5. Pégala en NGROK_URL y reinicia el backend

# Frontend: enlaces en correos de bienvenida (Administración).
APP_URL=http://localhost:4200

# ----- CORS: origen del frontend (Angular dev server o dominio producción) -----
CORS_ORIGIN=http://localhost:4200

# ----- JWT -----
JWT_SECRET=cambia-esta-clave-en-produccion-es-muy-importante
JWT_EXPIRES_IN=8h

# ----- MySQL -----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=gestionincidentes
DB_CONNECTION_LIMIT=10

# ----- Seed automático de usuarios demo al arrancar (true/false) -----
AUTO_SEED_USERS=true

# ----- Política: no quemar datos en código -----
# Esquema y catálogos vienen de la BD gestionincidentes (dump oficial).
# Credenciales LDAP solo en .env / directorio Docker.

# ----- LDAP (OpenLDAP / Active Directory) -----
# Login: primero directorio; si no está en LDAP, cuentas locales creadas en MySQL (Administración).
# Los uid del directorio NO necesitan fila en users (rol/agencia por defecto abajo).
LDAP_ENABLED=false
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=cn=readonly,dc=ims,dc=local
LDAP_BIND_PASSWORD=readonlypass
LDAP_BASE_DN=ou=users,dc=ims,dc=local
LDAP_USER_ATTRIBUTE=uid
LDAP_TIMEOUT_MS=5000
LDAP_TLS_REJECT_UNAUTHORIZED=true
# Si el uid solo existe en el directorio (no en tabla usuarios):
LDAP_DEFAULT_ROLE_ID=RP-3
LDAP_DEFAULT_AGENCY_CODE=CSJ

# ----- Google Maps (frontend + geocodificación backend) -----
# Obligatoria para mapas en el frontend. El Angular la pide a GET /api/config/public (no va en el repo).
# Restrinja la key en Google Cloud: HTTP referrers (localhost:4200, dominio producción) + APIs necesarias.
# Si la key estuvo expuesta en GitHub, rótela antes de poner la nueva aquí.
# GOOGLE_MAPS_API_KEY=

# ----- EMAIL (Resend API) -----
# El sistema usa Resend para envío de correos (OTP, bienvenida, notificaciones de incidentes).
# 1. Crea una cuenta en https://resend.com
# 2. Ve a API Keys → Create API Key
# 3. Verifica tu dominio en Resend → Domains (necesario para enviar a cualquier destinatario)
# 4. Pega tu API key y configura el remitente con tu dominio verificado
RESEND_API_KEY=tu_api_key_de_resend
SMTP_FROM=IMS NOVA <noreply@tudominio.com>
