# ----- Servidor -----
PORT=3000
NODE_ENV=development

# ----- CORS: origen del frontend (Angular dev server) -----
CORS_ORIGIN=http://localhost:4200

# ----- JWT -----
JWT_SECRET=cambia-esta-clave-en-produccion-es-muy-importante
JWT_EXPIRES_IN=8h

# ----- MySQL -----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=ims_db
DB_CONNECTION_LIMIT=10

# ----- Seed automático de cuentas locales al arrancar (true/false) -----
# Por defecto desactivado: los usuarios viven en LDAP (Docker). Ver sql/seed_users.js.
AUTO_SEED_USERS=false

# ----- LDAP (OpenLDAP / Active Directory) -----
# Login: primero directorio; si no está en LDAP, cuentas locales creadas en MySQL (Administración).
# Los uid del directorio NO necesitan fila en users (rol/agencia por defecto abajo).
LDAP_ENABLED=false
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=ims,dc=local
LDAP_BIND_PASSWORD=adminpassword
LDAP_BASE_DN=dc=ims,dc=local
LDAP_USER_ATTRIBUTE=uid
LDAP_TIMEOUT_MS=5000
LDAP_TLS_REJECT_UNAUTHORIZED=true
# Si el uid solo existe en el directorio (no en MySQL):
LDAP_DEFAULT_ROLE_ID=RP-3
LDAP_DEFAULT_AGENCY_CODE=CENTRAL
